<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>DotNet10Demo</RootNamespace>
    <AssemblyName>DotNet10Demo</AssemblyName>
  </PropertyGroup>

  <!-- Exclude standalone file-based scripts (they use #! shebang and #: directives
       that are only valid when run via 'dotnet run script.cs') -->
  <ItemGroup>
    <Compile Remove="Features\FileBasedApps\SampleScripts\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.0" />
  </ItemGroup>

</Project>
